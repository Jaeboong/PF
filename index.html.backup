</div>

<script>
  const slides = document.getElementById('slides');
  const total = slides.children.length;
  const indicator = document.getElementById('indicator');
  const pageNum = document.getElementById('pageNum');
  const scrollGuide = document.getElementById('scrollGuide');
  const galleryShells = document.querySelectorAll('.gallery-shell');
  let isAnimating = false;
  let guideDismissed = false;

  function dismissGuide() {
    if (!scrollGuide || guideDismissed) return;
    guideDismissed = true;
    scrollGuide.classList.add('hidden');
  }

  // Create dots
  for (let i = 0; i < total; i++) {
    const dot = document.createElement('div');
    dot.className = 'dot' + (i === 0 ? ' active' : '');
    dot.addEventListener('click', () => goTo(i));
    indicator.appendChild(dot);
  }

  function goTo(i) {
    const target = slides.children[i];
    if (!target || isAnimating) return;
    dismissGuide();
    isAnimating = true;
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    window.setTimeout(() => {
      isAnimating = false;
    }, 700);
  }

  function getCurrent() {
    const scrollTop = slides.scrollTop;
    const slideHeight = window.innerHeight;
    return Math.round(scrollTop / slideHeight);
  }

  function updateIndicator() {
    const current = getCurrent();
    const dots = indicator.querySelectorAll('.dot');
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
    pageNum.textContent = `${current + 1} / ${total}`;
    if (current > 0) dismissGuide();
  }

  slides.addEventListener('scroll', updateIndicator);

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const current = getCurrent();
    if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') {
      e.preventDefault();
      if (current < total - 1) goTo(current + 1);
    }
    if (e.key === 'ArrowUp' || e.key === 'PageUp') {
      e.preventDefault();
      if (current > 0) goTo(current - 1);
    }
  });

  // Mouse wheel → vertical paging
  slides.addEventListener('wheel', (e) => {
    if (isAnimating || Math.abs(e.deltaY) < Math.abs(e.deltaX)) {
      return;
    }

    const current = getCurrent();
    const currentSlide = slides.children[current];
    if (!currentSlide) return;

    const canScrollDown =
      e.deltaY > 0 &&
      currentSlide.scrollTop + currentSlide.clientHeight < currentSlide.scrollHeight - 1;
    const canScrollUp = e.deltaY < 0 && currentSlide.scrollTop > 0;

    if (canScrollDown || canScrollUp) return;

    e.preventDefault();
    if (e.deltaY > 0 && current < total - 1) goTo(current + 1);
    if (e.deltaY < 0 && current > 0) goTo(current - 1);
  }, { passive: false });

  slides.addEventListener('touchstart', dismissGuide, { passive: true });
  slides.addEventListener('mousedown', dismissGuide, { passive: true });

  galleryShells.forEach((shell) => {
    const track = shell.querySelector('.gallery-track');
    const cards = shell.querySelectorAll('.gallery-card');
    const prevBtn = shell.querySelector('.gallery-btn.prev');
    const nextBtn = shell.querySelector('.gallery-btn.next');
    const count = shell.querySelector('.gallery-count');

    if (!track || !cards.length) return;

    const clearHint = () => {
      shell.classList.remove('is-hinting');
    };

    const getIndex = () => {
      if (!track.clientWidth) return 0;
      return Math.round(track.scrollLeft / track.clientWidth);
    };

    const updateGalleryState = () => {
      const index = getIndex();
      if (count) count.textContent = `${index + 1} / ${cards.length}`;
      if (prevBtn) prevBtn.disabled = index <= 0;
      if (nextBtn) nextBtn.disabled = index >= cards.length - 1;
    };

    const goToCard = (index) => {
      const targetIndex = Math.max(0, Math.min(index, cards.length - 1));
      track.scrollTo({
        left: targetIndex * track.clientWidth,
        behavior: 'smooth'
      });
      clearHint();
      window.setTimeout(updateGalleryState, 220);
    };

    shell.classList.add('is-hinting');
    shell.addEventListener('pointerdown', clearHint, { passive: true });
    shell.addEventListener('mouseenter', clearHint, { passive: true });

    track.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaY) > Math.abs(e.deltaX) || e.shiftKey) {
        e.preventDefault();
        track.scrollLeft += e.shiftKey ? e.deltaX + e.deltaY : e.deltaY;
      }
      clearHint();
      window.requestAnimationFrame(updateGalleryState);
      e.stopPropagation();
    }, { passive: false });

    track.addEventListener('scroll', () => {
      clearHint();
      window.requestAnimationFrame(updateGalleryState);
    }, { passive: true });

    prevBtn?.addEventListener('click', () => {
      goToCard(getIndex() - 1);
    });

    nextBtn?.addEventListener('click', () => {
      goToCard(getIndex() + 1);
    });

    window.addEventListener('resize', updateGalleryState);
    updateGalleryState();
  });

  updateIndicator();
</script>

</body>
</html>
